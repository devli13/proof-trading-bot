# ─────────────────────────────────────────────────────────────────────────────
# Proof trading bot — environment
# Copy to `.env` and fill in. Safe defaults target the public DEVNET (paper money).
# ─────────────────────────────────────────────────────────────────────────────

# Network: devnet (default) | local | custom
# devnet/local are auto-allowed. "custom" (or overriding chain/gateway) requires
# PROOF_ALLOW_REAL=1 below — a guard against accidentally trading real money.
PROOF_NETWORK=devnet

# Optional explicit overrides (defaults are derived from PROOF_NETWORK):
# PROOF_GATEWAY_URL=https://api.dev.proof.trade
# PROOF_CHAIN_ID=exchange-devnet-1
# PROOF_FAUCET_URL=https://faucet.dev.proof.trade

# Market id to observe/trade in the smoke test and the default strategy.
PROOF_MARKET=1

# ── Funding / wallet (pick ONE; listed by precedence) ────────────────────────
# 1) Bring-your-own funded private key (hex). REQUIRED for Vercel/serverless,
#    where there is no writable keystore. Get one by redeeming an access code
#    once (path 2) and copying privateKeyHex here.
# PROOF_PRIVATE_KEY=

# 2) Paper-trading competition access code -> server redeems a funded key for you.
#    Needs the contest redeem endpoint.
# PROOF_ACCESS_CODE=
# PROOF_REDEEM_URL=https://<contest-site>/access-code/redeem

# 3) Privileged devnet faucet token (Proof-team internal). Funds a freshly
#    generated/keystore key via POST {faucet}/drip.
# PROOF_FAUCET_TOKEN=

# Where to persist a generated/redeemed key locally (gitignored). Ignored on
# read-only filesystems like Vercel.
KEYSTORE_PATH=.keys/devnet.json

# Gateway API key (only if the gateway was started with --api-key).
# PROOF_API_KEY=

# ── Risk caps (enforced by the runner before every order) ────────────────────
MAX_ORDER_QTY=1
MAX_OPEN_ORDERS=10
TICK_INTERVAL_MS=5000

# ── Safety / misc ────────────────────────────────────────────────────────────
# Must be 1/true to run against anything that isn't the known devnet/local preset.
PROOF_ALLOW_REAL=0
LOG_LEVEL=info
# LOG_JSON=1   # set for structured JSON logs (default is pretty console output)

# ── Vercel cron only ─────────────────────────────────────────────────────────
# Shared secret Vercel sends as `Authorization: Bearer <CRON_SECRET>` on cron
# invocations of /api/tick. Set the same value in the Vercel project env.
# CRON_SECRET=
