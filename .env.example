# ─────────────────────────────────────────────────────────────────────────────
# proof-trading-bot — environment. Copy to `.env` and fill in.
# Safe defaults target the public DEVNET (paper money). NEVER commit `.env`.
# ─────────────────────────────────────────────────────────────────────────────

# Network: devnet (default) | local | custom. Anything other than the devnet/local
# presets requires PROOF_ALLOW_REAL=1 — a guard against trading real money.
PROOF_NETWORK=devnet
# PROOF_GATEWAY_URL=https://api.dev.proof.trade
# PROOF_CHAIN_ID=exchange-devnet-1
PROOF_ALLOW_REAL=0

# ── Funding / wallet (pick one; see README) ──────────────────────────────────
# PROOF_PRIVATE_KEY=         # bring-your-own funded hex key (REQUIRED on Vercel)
# PROOF_ACCESS_CODE=         # beta-challenge access code (redeems a funded key)
# PROOF_REDEEM_URL=https://beta.proof.trade/access-code/redeem
# PROOF_FAUCET_TOKEN=        # privileged devnet faucet (Proof-team internal)
KEYSTORE_PATH=.keys/devnet.json

# ── Strategy selection / target event ────────────────────────────────────────
PROOF_IMPACT_EVENT=203                 # impact market to trade (HYPE / CLARITY Act)
STRATEGIES=market-maker,parity-arb     # comma-separated; on Vercel cron favor: parity-arb
MM_MARKET=0                            # 0 = the event's underlying perp

# ── Sizing (qty is in 10^-szDecimals units; szDecimals=2 ⇒ qty 100 = 1 contract) ──
MM_ORDER_QTY=10                        # 0.1 HYPE ≈ $7
MM_MAX_POSITION=100                    # 1 HYPE ≈ $69
MM_SPREAD_BPS=30                       # 0.30%
ARB_ORDER_QTY=100                      # 1 binary contract (binary lot size = 100)
ARB_MIN_EDGE_BPS=25                    # min parity dislocation to act
ARB_VOID_SAFETY_BPS=50                 # extra buffer for VOID tail risk
ARB_CONDITIONAL_ENABLED=0              # opt-in DIRECTIONAL conditional basket (not an arb)

# ── Risk / kill-switch ───────────────────────────────────────────────────────
MIN_MARGIN_RATIO_BPS=2000              # 20% — cancel-all + halt below this
MAX_DRAWDOWN_BPS=1000                  # 10% session drawdown — cancel-all + halt
MAX_ORDER_QTY=1000
MAX_OPEN_ORDERS=20

# ── Lifecycle / cadence ──────────────────────────────────────────────────────
RESOLUTION_GUARD_MS=86400000           # stop arbing within 24h of the deadline
MARKET_CACHE_MS=60000
TICK_INTERVAL_MS=5000                  # local loop cadence (`pnpm run`)

# ── Tracking (Supabase / Postgres) ───────────────────────────────────────────
# Full pooler connection string incl. password. Local: session pooler (:5432).
# Vercel serverless: prefer the TRANSACTION pooler (:6543). Never commit.
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres
DB_SCHEMA=proof_bot                    # dedicated schema — isolates from other projects

# ── Safety / Vercel ──────────────────────────────────────────────────────────
DRY_RUN=0                              # 1 = compute + log orders, submit nothing
LOG_LEVEL=info
# LOG_JSON=1
# CRON_SECRET=                          # Vercel sends it as Bearer to /api/tick
